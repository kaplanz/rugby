{
  "name": "site",
  "type": "module",
  "private": true,
  "workspaces": [
    "pkg/*"
  ],
  "scripts": {
    "build": "eleventy",
    "build:demo": "bun --cwd=../apps/web run build",
    "prebuild": "bun run build:demo",
    "start": "eleventy --serve --quiet",
    "dev": "eleventy --serve"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.0.0",
    "htmlnano": "^3.0.0",
    "lightningcss": "^1.30.2",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-github-alerts": "^1.0.0",
    "markdown-it-inline-footnotes": "workspace:*"
  }
}
