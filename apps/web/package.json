{
  "name": "rugby",
  "type": "module",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "../../bind/wasm/pkg"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "build:wasm": "wasm-pack build ../../bind/wasm",
    "check": "biome check --write .",
    "clean": "rm -rf ./dist",
    "dev": "vite",
    "fix": "biome lint --write .",
    "fmt": "biome format --write .",
    "prebuild": "bun run build:wasm",
    "predev": "bun run prebuild",
    "preview": "vite preview"
  },
  "dependencies": {
    "@shoelace-style/shoelace": "^2.20.1",
    "lit": "^3.3.2",
    "lucide": "^0.577.0",
    "rugby-wasm": "workspace:pkg",
    "vite-plugin-wasm": "^3.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "wasm-pack": "^0.14.0"
  }
}
